{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Explore app in Brave",
      "type": "chrome",
      "request": "launch",
      "runtimeExecutable": "C:\\Program Files\\BraveSoftware\\Brave-Browser\\Application\\brave.exe",
      "url": "http://127.0.0.1:5173/",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "ensure dev server (5173)",
      "sourceMaps": true
    },
    {
      "name": "Explore app in Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://127.0.0.1:5173/",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "ensure dev server (5173)",
      "sourceMaps": true
    },
    {
      "name": "Explore app in Edge",
      "type": "msedge",
      "request": "launch",
      "runtimeExecutable": "C:\\Program Files (x86)\\Microsoft\\Edge\\Application\\msedge.exe",
      "url": "http://127.0.0.1:5173/",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "ensure dev server (5173)",
      "sourceMaps": true
    },
    {
      "name": "Debug current Vitest file",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "node",
      "args": [
        "./node_modules/vitest/vitest.mjs",
        "run",
        "${file}"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "smartStep": true
    }
  ]
}
